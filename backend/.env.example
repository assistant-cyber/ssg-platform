# ─── Security ───────────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
DEBUG=true

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default — good for development)
DATABASE_URL=sqlite:///./ssg.db

# PostgreSQL / Supabase (recommended for production)
# DATABASE_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ─── Storage ─────────────────────────────────────────────────────────────────
# "local" stores files on disk under UPLOAD_DIR; "s3" stores files in S3-compatible storage.
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# S3 / Supabase Storage settings (only needed when STORAGE_TYPE=s3)
# S3_BUCKET_NAME=ssg-platform
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
# AWS_ACCESS_KEY_ID=<supabase-s3-key>
# AWS_SECRET_ACCESS_KEY=<supabase-s3-secret>

# ─── Reports ─────────────────────────────────────────────────────────────────
REPORTS_OUTPUT_PATH=./reports

# ─── AI (optional — only needed for AI/hybrid parsing mode) ─────────────────
# ANTHROPIC_API_KEY=sk-ant-...
